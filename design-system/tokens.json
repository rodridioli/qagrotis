{
  "$schema": "./tokens.schema.json",
  "meta": {
    "version": "2.0.0",
    "description": "QAgrotis Design System — single source of truth for all visual tokens",
    "brand": "QAgrotis",
    "primaryHue": "168deg (Agrotis Green)"
  },

  "primitive": {
    "description": "Raw values — never use directly in UI, always via semantic tokens",
    "green": {
      "50":  "#edfaf6",
      "100": "#d0f2e8",
      "200": "#9ee5d2",
      "300": "#5cd0b8",
      "400": "#2ab89e",
      "500": "#009e83",
      "600": "#008068",
      "700": "#00735D",
      "800": "#005c4b",
      "900": "#003d32"
    },
    "secondary": {
      "50":  "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a"
    },
    "grey": {
      "50":  "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "800": "#1f2937",
      "900": "#111827"
    },
    "red":    { "100": "#fee2e2", "500": "#ef4444", "700": "#b91c1c" },
    "amber":  { "100": "#fef3c7", "400": "#fbbf24", "600": "#d97706" },
    "orange": { "100": "#ffedd5", "500": "#f97316", "700": "#c2410c" },
    "blue":   { "100": "#dbeafe", "500": "#3b82f6", "700": "#1d4ed8" },
    "white":  "#ffffff",
    "black":  "#000000"
  },

  "themes": {
    "light": {
      "description": "Default light theme — clean, professional, high readability",
      "semantic": {
        "brand-primary":    "#00735D",
        "surface-default":  "#f4f5f9",
        "surface-card":     "#ffffff",
        "surface-input":    "#f8f9fc",
        "text-primary":     "#1a202c",
        "text-secondary":   "#6b7280",
        "border-default":   "#e5e7eb"
      },
      "base": {
        "background":            "#ffffff",
        "foreground":            "#1a202c",
        "card":                  "#ffffff",
        "card-foreground":       "#1a202c",
        "popover":               "#ffffff",
        "popover-foreground":    "#1a202c",
        "primary":               "#00735D",
        "primary-foreground":    "#ffffff",
        "secondary":             "#f4f5f9",
        "secondary-foreground":  "#1a202c",
        "muted":                 "#f4f5f9",
        "muted-foreground":      "#6b7280",
        "accent":                "#f4f5f9",
        "accent-foreground":     "#1a202c",
        "destructive":           "#ef4444",
        "destructive-foreground":"#ffffff",
        "border":                "#e5e7eb",
        "input":                 "#e5e7eb",
        "ring":                  "#00735D"
      }
    },
    "dark": {
      "description": "Dark theme — deep navy surfaces, bright teal accents, premium feel",
      "rationale": "Surfaces use desaturated navy blue-greys (not pure black) for depth and reduced eye strain. Brand primary is brightened to primary-400 to maintain contrast on dark backgrounds.",
      "semantic": {
        "brand-primary":    "#2ab89e",
        "surface-default":  "#0f1117",
        "surface-card":     "#161923",
        "surface-input":    "#1e2235",
        "text-primary":     "#e8edf5",
        "text-secondary":   "#8b95a5",
        "border-default":   "#252c3d"
      },
      "base": {
        "background":            "#0f1117",
        "foreground":            "#e8edf5",
        "card":                  "#161923",
        "card-foreground":       "#e8edf5",
        "popover":               "#1e2235",
        "popover-foreground":    "#e8edf5",
        "primary":               "#2ab89e",
        "primary-foreground":    "#001a12",
        "secondary":             "#1e2235",
        "secondary-foreground":  "#e8edf5",
        "muted":                 "#1e2235",
        "muted-foreground":      "#8b95a5",
        "accent":                "#252c3d",
        "accent-foreground":     "#e8edf5",
        "destructive":           "#f87171",
        "destructive-foreground":"#1a0000",
        "border":                "#252c3d",
        "input":                 "#1e2235",
        "ring":                  "#2ab89e"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "var(--font-roboto), ui-sans-serif, system-ui, sans-serif",
      "mono": "var(--font-geist-mono), ui-monospace, monospace"
    },
    "fontSize": {
      "xs":   "0.75rem",
      "sm":   "0.875rem",
      "base": "1rem",
      "lg":   "1.125rem",
      "xl":   "1.25rem",
      "2xl":  "1.5rem",
      "3xl":  "1.875rem",
      "4xl":  "2.25rem"
    },
    "fontWeight": {
      "regular":  "400",
      "medium":   "500",
      "semibold": "600",
      "bold":     "700"
    },
    "lineHeight": {
      "tight":   "1.25",
      "normal":  "1.5",
      "relaxed": "1.75"
    }
  },

  "spacing": {
    "description": "Base-8px grid",
    "1": "8px",
    "2": "16px",
    "3": "24px",
    "4": "32px",
    "5": "40px",
    "6": "48px",
    "8": "64px"
  },

  "radius": {
    "none":   "0px",
    "custom": "4px",
    "sm":     "6px",
    "md":     "8px",
    "lg":     "12px",
    "xl":     "16px",
    "full":   "9999px"
  },

  "shadows": {
    "card":   "0 1px 3px 0 rgb(0 0 0 / 0.08), 0 1px 2px -1px rgb(0 0 0 / 0.06)",
    "card-dark": "0 1px 3px 0 rgb(0 0 0 / 0.40), 0 1px 2px -1px rgb(0 0 0 / 0.30)"
  },

  "zIndex": {
    "base":    "0",
    "raised":  "10",
    "dropdown":"100",
    "sticky":  "200",
    "overlay": "300",
    "modal":   "400",
    "toast":   "500"
  },

  "animation": {
    "duration": {
      "fast":   "100ms",
      "normal": "200ms",
      "slow":   "300ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in":      "cubic-bezier(0.4, 0, 1, 1)",
      "out":     "cubic-bezier(0, 0, 0.2, 1)"
    }
  }
}
