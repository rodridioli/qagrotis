generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  plan                   Plan      @default(TRIAL)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?
  accounts               Account[]
  sessions               Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Cliente {
  id           String   @id
  nomeFantasia String
  razaoSocial  String?
  cpfCnpj      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

model Sistema {
  id          String    @id
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cenarios    Cenario[]
  modulos     Modulo[]
  suites      Suite[]
}

model Modulo {
  id          String    @id
  name        String
  description String?
  sistemaId   String
  sistemaName String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cenarios    Cenario[]
  sistema     Sistema   @relation(fields: [sistemaId], references: [id])
  suites      Suite[]

  @@index([active, sistemaName])
  @@index([sistemaId])
}

model Cenario {
  id                String      @id
  scenarioName      String
  system            String
  module            String
  client            String      @default("")
  execucoes         Int         @default(0)
  erros             Int         @default(0)
  suites            Int         @default(0)
  tipo              String
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  createdBy         String?
  risco             String?
  regraDeNegocio    String?
  descricao         String?
  caminhoTela       String?
  preCondicoes      String?
  bdd               String?
  resultadoEsperado String?
  urlAmbiente       String?
  objetivo          String?
  urlScript         String?
  usuarioTeste      String?
  senhaTeste        String?
  senhaFalsa        String?
  steps             Json        @default("[]")
  deps              String[]    @default([])
  credencialId      String?
  systemId          String?
  moduleId          String?
  updatedAt         DateTime    @updatedAt
  credencial        Credencial? @relation(fields: [credencialId], references: [id])
  modulo            Modulo?     @relation(fields: [moduleId], references: [id])
  sistema           Sistema?    @relation(fields: [systemId], references: [id])

  @@index([active])
  @@index([system])
  @@index([active, system])
  @@index([createdBy])
  @@index([createdAt])
}

model Suite {
  id         String   @id
  suiteName  String
  versao     String
  sistema    String
  modulo     String
  cliente    String   @default("")
  tipo       String
  objetivo   String?
  active     Boolean  @default(true)
  encerrada  Boolean  @default(false)
  createdAt  DateTime @default(now())
  cenarios   Json     @default("[]")
  historico  Json     @default("[]")
  sistemaId  String?
  moduloId   String?
  updatedAt  DateTime @updatedAt
  moduloRef  Modulo?  @relation(fields: [moduloId], references: [id])
  sistemaRef Sistema? @relation(fields: [sistemaId], references: [id])

  @@index([active])
  @@index([createdAt])
  @@index([active, sistema])
}

model CreatedUser {
  id                  String           @id
  name                String
  email               String           @unique
  type                String           @default("Padrão")
  classificacao       String?
  photoPath           String?
  dataNascimento      DateTime?
  horarioEntrada      String?
  horarioSaida        String?
  formatoTrabalho     String?
  /// * Dias presenciais no modo Híbrido: `["seg","ter",…]`
  diasTrabalhoHibrido Json?
  password            String           @default("")
  createdAt           DateTime         @default(now())
  accessProfile       AccessProfile?
  cep                 String?
  address             String?
  addressNumber       String?
  neighborhood        String?
  country             String?
  state               String?
  city                String?
  phone               String?
  emergencyContact    String?
  instagram           String?
  linkedin            String?
  education           Json?
  courses             Json?
  languages           Json?
  certifications      Json?
  careerHistory       Json?
  notifications       Notification[]
  userBadges          UserBadge[]
  teamAsLeader        TeamMembership[] @relation("TeamLeader")
  teamAsMember        TeamMembership?  @relation("TeamMember")
}

/// Credenciais Jira por usuário × instância. Chave composta (userId, jiraUrl) permite
/// que um mesmo utilizador (ex: MGR) configure múltiplas instâncias Atlassian
/// (ex: agrotis.atlassian.net e agrosem.atlassian.net) para editar worklogs de
/// qualquer projecto sem depender das credenciais individuais de cada membro.
model UserJiraCredentials {
  userId    String
  jiraUrl   String
  jiraEmail String
  apiToken  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, jiraUrl])
}

/// Token API Clockwork Pro (registo único por instância). Campo apiToken cifrado como em UserJiraCredentials.
model ClockworkIntegration {
  id              String   @id @default("default")
  apiToken        String
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserProfile {
  userId              String         @id
  name                String?
  email               String?
  type                String?
  classificacao       String?
  photoPath           String?
  dataNascimento      DateTime?
  horarioEntrada      String?
  horarioSaida        String?
  formatoTrabalho     String?
  diasTrabalhoHibrido Json?
  accessProfile       AccessProfile?
  cep                 String?
  address             String?
  addressNumber       String?
  neighborhood        String?
  country             String?
  state               String?
  city                String?
  phone               String?
  emergencyContact    String?
  instagram           String?
  linkedin            String?
  education           Json?
  courses             Json?
  languages           Json?
  certifications      Json?
  careerHistory       Json?
}

model InactiveUser {
  userId String @id
}

model InviteToken {
  token     String   @id
  userId    String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([userId])
  @@index([expiresAt])
}

model EquipeChapter {
  id        String                @id @default(cuid())
  tema      String
  /// * Calendário do chapter (meia-noite UTC do dia civil).
  data      DateTime
  hyperlink String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  authors   EquipeChapterAuthor[]
  ratings   EquipeChapterRating[]

  @@index([data])
}

/// * Avaliação anónima na UI (autor guardado como userId no servidor).
model EquipeChapterRating {
  id        String        @id @default(cuid())
  chapterId String
  userId    String
  stars     Int
  comment   String        @default("")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chapter   EquipeChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([chapterId, createdAt])
}

model EquipeChapterAuthor {
  chapterId String
  userId    String
  chapter   EquipeChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@id([chapterId, userId])
  @@index([userId])
}

/// * Avaliação de desempenho por usuário (avaliado); gestor grava competências e situação.
model IndividualPerformanceEvaluation {
  id               String                                @id @default(cuid())
  evaluatedUserId  String
  evaluatorUserId  String
  /// * Sequência por usuário avaliado (ex.: 1, 2, 3…).
  codigo           Int
  status           IndividualPerformanceEvaluationStatus @default(RASCUNHO)
  /// * Mapa competênciaId → índice da coluna 0..4 (Não Atende … Excelente).
  selections       Json                                  @default("{}")
  /// * Percentual global (planilha); nulo quando incompleto em rascunho.
  pontuacaoPercent Float?
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt
  /// * Período de referência (trimestre ou semestre).
  periodo          String                                @default("T1_TRIMESTRE")

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
}

model Credencial {
  id          String    @id
  nome        String
  urlAmbiente String?
  usuario     String
  senha       String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cenarios    Cenario[]

  @@index([active])
  @@index([createdAt])
}

model Integracao {
  id        String   @id
  descricao String   @default("")
  provider  String
  model     String
  apiKey    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([createdAt])
}

/// *
///  * Feedback individual por usuário avaliado; tipo determina os campos obrigatórios.
///  * Tipos: POSITIVO | DESENVOLVIMENTO | CORRETIVO | FORMAL_CICLO | TREZENTOS_SESSENTA
model IndividualFeedback {
  id              String                   @id @default(cuid())
  evaluatedUserId String
  evaluatorUserId String
  /// * Sequência por usuário avaliado (ex.: 1, 2, 3…).
  codigo          Int
  tipo            String
  status          IndividualFeedbackStatus @default(RASCUNHO)
  /// * Campos dinâmicos por tipo: { contexto, feedback, impacto, … }
  campos          Json                     @default("{}")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  /// * Período de referência (trimestre ou semestre)
  periodo         String                   @default("T1_TRIMESTRE")

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
}

model IndividualProgressao {
  id              String   @id @default(cuid())
  evaluatedUserId String
  createdByUserId String
  /// * Sequência por usuário avaliado (ex.: 1, 2, 3…) — exibido como PGS-001.
  codigo          Int
  data            DateTime
  /// * ADMISSAO | DISSIDIO | PROMOCAO | MERITO
  tipo            String
  /// * CLT | PJ | COOPERADO
  regime          String
  /// * Valor em centavos (ex.: 200000 = R$ 2.000,00).
  valor           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  /// * Cargo/função no momento da progressão.
  cargo           String?
  /// * Valor hora em centavos (ex.: 150000 = R$ 1.500,00).
  valorHora       Int?

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  createdAt DateTime         @default(now())
  user      CreatedUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserBadge {
  id         String      @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime    @default(now())
  user       CreatedUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model IndividualFerias {
  id              String   @id @default(cuid())
  evaluatedUserId String
  createdByUserId String
  codigo          Int
  inicio          DateTime
  dias            Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
}

model IndividualAusencias {
  id              String           @id @default(cuid())
  evaluatedUserId String
  createdByUserId String
  codigo          Int
  tipo            AusenciaTipo
  justificativa   String
  situacao        AusenciaSituacao @default(PENDENTE)
  motivoRecusa    String?
  aprovadoPorId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  dataFim         DateTime
  dataInicio      DateTime

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
  @@index([situacao])
}

/// Vínculo líder → membro para o módulo Equipes.
/// Um membro pertence a no máximo um líder (memberId unique).
model TeamMembership {
  id        String      @id @default(cuid())
  leaderId  String
  memberId  String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  leader    CreatedUser @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  member    CreatedUser @relation("TeamMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@index([leaderId])
  @@map("team_memberships")
}

/// * Configuração global de Produtos e Módulos para avaliações de domínio. Singleton (id = "global").
model DominioConfiguracao {
  id              String   @id @default("global")
  /// * [{ id: uuid, nome: string, modulos: [{ id: uuid, nome: string }] }]
  produtos        Json     @default("[]")
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
}

/// * Avaliação de domínio de um usuário sobre os módulos de produto da empresa.
model DominioAvaliacao {
  id               String                 @id @default(cuid())
  evaluatedUserId  String
  solicitadaPorId  String
  /// * Sequência por usuário avaliado (ex.: 1, 2, 3…).
  codigo           Int
  status           DominioAvaliacaoStatus @default(PENDENTE)
  /// * Percentual global calculado após preenchimento.
  resultadoPercent Float?
  /// * [{ produtoId: string, moduloId: string, estrelas: 1..5 }]
  respostas        Json                   @default("[]")
  /// * Snapshot da configuração de produtos/módulos no momento da solicitação.
  configSnapshot   Json                   @default("[]")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([evaluatedUserId, codigo])
  @@index([evaluatedUserId])
  @@index([status])
}

model ChapterRedemption {
  id         String   @id @default(cuid())
  userId     String
  prizeId    String
  prizeLabel String
  costPoints Int
  createdAt  DateTime @default(now())

  @@index([userId])
}

/// Entrada individual de worklog cacheada do Jira.
/// Armazenada por (userId, issueKey, startedAt) — garante histórico permanente
/// independente do limite de 92 dias da API Jira.
model JiraWorklogCache {
  id                  String   @id @default(cuid())
  userId              String
  issueKey            String
  projectName         String?
  typeField           String?
  status              String?
  startedAt           DateTime
  timeSpentSeconds    Int
  year                Int
  month               Int
  authorJiraAccountId String?
  priority            String?
  retornos            Int      @default(0)
  retornosByAssignee  Json     @default("{}")
  tag                 String?
  issueType           String?
  qtdCenariosErro     Int      @default(0)
  qtdCenariosQA       Int      @default(0)

  @@unique([userId, issueKey, startedAt])
  @@index([userId, year, month])
}

/// Marca de controle de sincronização por (userId, year, month).
/// Registra quando um mês foi sincronizado pela última vez com a API Jira.
/// Permite saber que um mês com zero worklogs foi de fato sincronizado.
///
/// jirasBroken    — contagem de Broken Test issues criadas pelo reporter no mês
/// (calculada via JQL independente de worklogs, igual à tela Lançamentos).
/// cenariosErroSum — soma de qtdCenariosQA das BT issues do reporter no mês
/// (usado como "Cenários com Erro" Tipo B no QA Dashboard).
model JiraWorklogSyncMarker {
  id              String   @id @default(cuid())
  userId          String
  year            Int
  month           Int
  syncedAt        DateTime @default(now())
  jirasBroken     Int      @default(0)
  cenariosErroSum Int      @default(0)

  @@unique([userId, year, month])
}

/// Cache persistente do accountId Jira por usuário.
/// Sobrevive ao force-sync (que apaga JiraWorklogCache) e garante que
/// ex-membros desativados no Jira continuem sendo sincronizados enquanto
/// o accountId for conhecido.
model JiraAccountIdCache {
  userId     String   @id
  accountId  String
  resolvedAt DateTime @updatedAt
  /// "email" | "displayName" | "db-worklog-cache" | "admin"
  resolvedBy String?
}

/// Atribuição de issue do kanban UX a um membro do sistema.
/// cardType distingue Demandas (status "UX" vindo de projetos externos) de
/// UX Tarefas (projeto UX, vinhas da coluna "Tarefas").
model KanbanAssignment {
  issueKey   String   @id
  userId     String
  cardType   String   @default("demanda")
  assignedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("kanban_assignments")
}

/// Estado local da coluna no kanban individual por membro.
/// Usado APENAS para Demandas — UX Tarefas derivam a coluna do status Jira.
model KanbanUserCardState {
  issueKey  String   @id
  userId    String
  column    String
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("kanban_user_card_states")
}

/// Sessão de time tracking para um card no kanban individual.
/// startedAt = null → timer pausado (card não está em "Em andamento").
/// accumulatedSeconds = soma dos segundos de todas as sessões anteriores finalizadas e postadas ao Clockwork.
model KanbanTimerSession {
  issueKey           String    @id
  userId             String
  /// Início da sessão atual; null quando o card não está em "Em andamento".
  startedAt          DateTime?
  /// Segundos totais de sessões anteriores encerradas.
  accumulatedSeconds Int       @default(0)
  summary            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@map("kanban_timer_sessions")
}

/// Rastreia cards em "In Approval" para comentários automáticos no Jira a cada 24 h úteis.
model KanbanInApprovalTracker {
  issueKey            String    @id
  userId              String
  cardType            String
  approverAccountId   String?
  approverDisplayName String?
  enteredAt           DateTime  @default(now())
  lastCommentAt       DateTime?

  @@index([userId])
  @@map("kanban_in_approval_trackers")
}

model Okr {
  id        String        @id @default(cuid())
  codigo    String        @unique
  ano       Int
  periodo   OkrPeriodo
  situacao  OkrSituacao   @default(ATIVO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  objetivos OkrObjetivo[]

  @@index([ano])
  @@index([situacao])
  @@map("okrs")
}

model OkrObjetivo {
  id                  String              @id @default(cuid())
  okrId               String
  descricao           String
  situacao            OkrObjetivoSituacao @default(ATIVO)
  motivoCancelamento  String?
  percentualConcluido Float               @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  keyResults          OkrKeyResult[]
  equipes             OkrObjetivoEquipe[]
  okr                 Okr                 @relation(fields: [okrId], references: [id], onDelete: Cascade)

  @@index([okrId])
  @@map("okr_objetivos")
}

model OkrObjetivoEquipe {
  objetivoId String
  equipe     OkrEquipe
  objetivo   OkrObjetivo @relation(fields: [objetivoId], references: [id], onDelete: Cascade)

  @@id([objetivoId, equipe])
  @@map("okr_objetivo_equipes")
}

model OkrKeyResult {
  id                   String             @id @default(cuid())
  objetivoId           String
  descricao            String
  unidade              OkrUnidade         @default(PERCENTUAL)
  unidadePersonalizada String?
  valorInicial         Float              @default(0)
  valorAtual           Float              @default(0)
  meta                 Float              @default(100)
  situacao             OkrKrSituacao      @default(ATIVO)
  motivoCancelamento   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  iniciativas          OkrIniciativa[]
  objetivo             OkrObjetivo        @relation(fields: [objetivoId], references: [id], onDelete: Cascade)
  evolucao             OkrKrEvolucao[]
  responsaveis         OkrKrResponsavel[]

  @@index([objetivoId])
  @@map("okr_key_results")
}

model OkrKrResponsavel {
  keyResultId String
  userId      String
  keyResult   OkrKeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@id([keyResultId, userId])
  @@index([userId])
  @@map("okr_kr_responsaveis")
}

model OkrKrEvolucao {
  id          String       @id @default(cuid())
  keyResultId String
  mes         Int
  ano         Int
  valor       Float
  createdAt   DateTime     @default(now())
  keyResult   OkrKeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@unique([keyResultId, mes, ano])
  @@index([keyResultId])
  @@map("okr_kr_evolucao")
}

model OkrIniciativa {
  id           String                     @id @default(cuid())
  keyResultId  String
  descricao    String
  status       OkrIniciativaStatus        @default(PENDENTE)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  responsaveis OkrIniciativaResponsavel[]
  keyResult    OkrKeyResult               @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@index([keyResultId])
  @@map("okr_iniciativas")
}

model OkrIniciativaResponsavel {
  iniciativaId String
  userId       String
  iniciativa   OkrIniciativa @relation(fields: [iniciativaId], references: [id], onDelete: Cascade)

  @@id([iniciativaId, userId])
  @@index([userId])
  @@map("okr_iniciativa_responsaveis")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum AccessProfile {
  QA
  UX
  TW
  MGR
}

enum IndividualPerformanceEvaluationStatus {
  RASCUNHO
  CONCLUIDA
}

enum IndividualFeedbackStatus {
  RASCUNHO
  CONCLUIDA
}

enum NotificationType {
  FEEDBACK
  EVALUATION
  PROGRESSION
  ACHIEVEMENT
  ABSENCE_REQUEST
  DOMAIN_EVALUATION
}

enum AusenciaTipo {
  FALTA
  BANCO_HORAS
  ATESTADO
  OUTRO
  ATRASO
}

enum AusenciaSituacao {
  PENDENTE
  APROVADA
  RECUSADA
}

enum DominioAvaliacaoStatus {
  PENDENTE
  CONCLUIDA
}

enum OkrPeriodo {
  Q1
  Q2
  Q3
  Q4
}

enum OkrSituacao {
  ATIVO
  ENCERRADO
  CANCELADO
}

enum OkrObjetivoSituacao {
  ATIVO
  CANCELADO
}

enum OkrKrSituacao {
  ATIVO
  CANCELADO
}

enum OkrUnidade {
  PERCENTUAL
  REAL
  UNIDADES
  HORAS
  DIAS
  PERSONALIZADA
}

enum OkrIniciativaStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum OkrEquipe {
  QA
  UX
  TW
  GESTAO
}
