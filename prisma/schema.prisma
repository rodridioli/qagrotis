// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Connection config is in prisma.config.ts (Prisma 7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  TRIAL
  PRO
}

// ── Auth.js models ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan                   Plan      @default(TRIAL)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?

  accounts Account[]
  sessions Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Legacy (kept for schema compatibility) ────────────────────────────────────

model QaUser {
  id        String   @id
  name      String
  email     String   @unique
  type      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── QAgrotis domain models ────────────────────────────────────────────────────

model Cliente {
  id           String   @id
  nomeFantasia String
  razaoSocial  String?
  cpfCnpj      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Sistema {
  id          String   @id
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  modulos     Modulo[]
}

model Modulo {
  id          String   @id
  name        String
  description String?
  sistemaId   String
  sistemaName String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  sistema     Sistema  @relation(fields: [sistemaId], references: [id])
}

model Cenario {
  id                String    @id
  scenarioName      String
  system            String
  module            String
  client            String    @default("")
  execucoes         Int       @default(0)
  erros             Int       @default(0)
  suites            Int       @default(0)
  tipo              String
  active            Boolean   @default(true)
  createdAt         DateTime? @default(now())
  createdBy         String?
  risco             String?
  regraDeNegocio    String?
  descricao         String?
  caminhoTela       String?
  preCondicoes      String?
  bdd               String?
  resultadoEsperado String?
  urlScript         String?
  usuarioTeste      String?
  senhaTeste        String?
  senhaFalsa        String?
  steps             Json      @default("[]")
  deps              String[]  @default([])
}

// Suite stores cenarios and historico as embedded JSON arrays (denormalized)
model Suite {
  id        String   @id
  suiteName String
  versao    String
  sistema   String
  modulo    String
  cliente   String   @default("")
  tipo      String
  objetivo  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  cenarios  Json     @default("[]")
  historico Json     @default("[]")
}

// ── Auth / user management ────────────────────────────────────────────────────

// Users created by admins (have passwords, managed manually)
model CreatedUser {
  id        String   @id
  name      String
  email     String   @unique
  type      String   @default("Padrão")
  photoPath String?
  password  String   @default("")
  createdAt DateTime @default(now())
}

// Profile overrides for both mock and created users (name, email, type, photo)
model UserProfile {
  userId    String  @id
  name      String?
  email     String?
  type      String?
  photoPath String?
}

// Soft-delete registry for mock users (mock users cannot be deleted from constants)
model InactiveUser {
  userId String @id
}

// One-time invite links for new users to set their password
model InviteToken {
  token     String   @id
  userId    String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
}

// AI provider integrations (Google, OpenAI, Anthropic, Groq, OpenRouter)
model Integracao {
  id        String   @id
  descricao String   @default("")
  provider  String
  model     String
  apiKey    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
