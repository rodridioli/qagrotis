// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Connection config is in prisma.config.ts (Prisma 7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  TRIAL
  PRO
}

// ── Auth.js models ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan                   Plan      @default(TRIAL)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?

  accounts Account[]
  sessions Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Legacy (kept for schema compatibility) ────────────────────────────────────

model QaUser {
  id        String   @id
  name      String
  email     String   @unique
  type      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── QAgrotis domain models ────────────────────────────────────────────────────

model Cliente {
  id           String   @id
  nomeFantasia String
  razaoSocial  String?
  cpfCnpj      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Sistema {
  id          String   @id
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  modulos     Modulo[]
  cenarios    Cenario[]
  suites      Suite[]
}

model Modulo {
  id          String   @id
  name        String
  description String?
  sistemaId   String
  sistemaName String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  sistema     Sistema  @relation(fields: [sistemaId], references: [id])
  cenarios    Cenario[]
  suites      Suite[]
}

model Cenario {
  id                String    @id
  scenarioName      String
  system            String
  module            String
  client            String    @default("")
  execucoes         Int       @default(0)
  erros             Int       @default(0)
  suites            Int       @default(0)
  tipo              String
  active            Boolean   @default(true)
  createdAt         DateTime? @default(now())
  createdBy         String?
  risco             String?
  regraDeNegocio    String?
  descricao         String?
  caminhoTela       String?
  preCondicoes      String?
  bdd               String?
  resultadoEsperado String?
  urlAmbiente       String?
  objetivo          String?
  urlScript         String?
  usuarioTeste      String?
  senhaTeste        String?
  senhaFalsa        String?
  steps             Json      @default("[]")
  deps              String[]  @default([])
  credencialId      String?

  // Relationships
  systemId          String?
  moduleId          String?
  sistema           Sistema?    @relation(fields: [systemId], references: [id])
  modulo            Modulo?     @relation(fields: [moduleId], references: [id])
  credencial        Credencial? @relation(fields: [credencialId], references: [id])

  @@index([active])
  @@index([system])
  @@index([active, system])
  @@index([createdBy])
  @@index([createdAt])
}

// Suite stores cenarios and historico as embedded JSON arrays (denormalized)
model Suite {
  id        String   @id
  suiteName String
  versao    String
  sistema   String
  modulo    String
  cliente   String   @default("")
  tipo      String
  objetivo  String?
  active    Boolean  @default(true)
  encerrada Boolean  @default(false)
  createdAt DateTime @default(now())
  cenarios  Json     @default("[]")
  historico Json     @default("[]")

  // Relationships
  sistemaId String?
  moduloId  String?
  sistemaRef Sistema? @relation(fields: [sistemaId], references: [id])
  moduloRef  Modulo?  @relation(fields: [moduloId], references: [id])

  @@index([active])
  @@index([createdAt])
}

// ── Auth / user management ────────────────────────────────────────────────────

// Users created by admins (have passwords, managed manually)
model CreatedUser {
  id               String    @id
  name             String
  email            String    @unique
  type             String    @default("Padrão")
  classificacao    String?
  photoPath        String?
  dataNascimento   DateTime?
  horarioEntrada   String?
  horarioSaida     String?
  formatoTrabalho  String?
  /** Dias presenciais no modo Híbrido: `["seg","ter",…]` */
  diasTrabalhoHibrido Json?
  password         String    @default("")
  createdAt        DateTime  @default(now())
}

// Profile overrides for both mock and created users (name, email, type, photo)
model UserProfile {
  userId          String    @id
  name            String?
  email           String?
  type            String?
  classificacao   String?
  photoPath       String?
  dataNascimento  DateTime?
  horarioEntrada  String?
  horarioSaida    String?
  formatoTrabalho String?
  diasTrabalhoHibrido Json?
}

// Soft-delete registry for mock users (mock users cannot be deleted from constants)
model InactiveUser {
  userId String @id
}

// One-time invite links for new users to set their password
model InviteToken {
  token     String   @id
  userId    String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
}

// ── Equipe / Chapters ────────────────────────────────────────────────────────

model EquipeChapter {
  id        String   @id @default(cuid())
  tema      String
  /** Calendário do chapter (meia-noite UTC do dia civil). */
  data      DateTime
  hyperlink String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authors   EquipeChapterAuthor[]

  @@index([data])
}

model EquipeChapterAuthor {
  chapterId String
  userId    String
  chapter   EquipeChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@id([chapterId, userId])
  @@index([userId])
}

// Test environment credentials (URL, username, password) reusable across scenarios
model Credencial {
  id          String    @id
  nome        String
  urlAmbiente String?
  usuario     String
  senha       String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  cenarios    Cenario[]

  @@index([active])
  @@index([createdAt])
}

// AI provider integrations (Google, OpenAI, Anthropic, Groq, OpenRouter)
model Integracao {
  id        String   @id
  descricao String   @default("")
  provider  String
  model     String
  apiKey    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@index([createdAt])
}
